{
  "name": "@wlearn/cluster",
  "version": "0.1.0",
  "description": "Clustering library from scratch in C11 -- K-Means, Mini-batch K-Means, DBSCAN, Hierarchical, FastPAM k-medoids, validation indices",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": { "require": "./src/index.js", "default": "./src/index.js" }
  },
  "files": [
    "src/",
    "wasm/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node test/test.js",
    "build": "bash scripts/build-wasm.sh",
    "verify": "bash scripts/verify-exports.sh"
  },
  "keywords": [
    "clustering",
    "kmeans",
    "dbscan",
    "hierarchical",
    "medoids",
    "silhouette",
    "machine-learning",
    "wasm",
    "webassembly",
    "wlearn"
  ],
  "author": "Anton Zemlyansky",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/cluster.git"
  },
  "license": "Apache-2.0"
}
